{
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "installCommand": "npm ci --no-audit",
        "buildCommand": "npm run build"
      }
    },
    {
      "src": "api/serverless.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/serverless.js" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
